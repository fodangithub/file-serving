@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_state == DownloadState.Idle)
{
    <button class="download-btn" @onclick="StartDownload" disabled="@_disabled">Download</button>
}
else if (_state == DownloadState.Downloading)
{
    <div class="download-progress">
        <div class="download-bar" style="width: @_progress.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
        <span class="download-percent">@_progress.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%</span>
    </div>
    <span class="download-speed">@_speedText</span>
}
else if (_state == DownloadState.Done)
{
    <span class="download-done">&#10003;</span>
}
else if (_state == DownloadState.Error)
{
    <div class="download-actions">
        <button class="download-btn download-error" @onclick="ResumeDownload">
            @(_resumable ? "Resume" : "Retry")
        </button>
        @if (_resumable)
        {
            <button class="download-btn download-restart" @onclick="StartOver">Start Over</button>
        }
    </div>
}

@code {
    [Parameter] public string Url { get; set; } = "";
    [Parameter] public string FileName { get; set; } = "";

    private DownloadState _state = DownloadState.Idle;
    private double _progress;
    private string _speedText = "";
    private bool _disabled;
    private bool _resumable;
    private DotNetObjectReference<DownloadButton>? _dotNetRef;

    [JSInvokable]
    public void OnProgress(double percent, long bytesPerSecond)
    {
        _progress = percent;
        if (bytesPerSecond > 0)
            _speedText = FormatSpeed(bytesPerSecond);
        StateHasChanged();
    }

    [JSInvokable]
    public void OnComplete()
    {
        _state = DownloadState.Done;
        _progress = 100;
        _speedText = "";
        StateHasChanged();
        _ = ResetAfterDelay();
    }

    [JSInvokable]
    public void OnError(string message)
    {
        _state = DownloadState.Error;
        _speedText = "";
        _disabled = false;
        _ = CheckResumable();
    }

    private async Task CheckResumable()
    {
        try
        {
            _resumable = await JS.InvokeAsync<bool>("hasPartialDownload", Url, FileName);
        }
        catch
        {
            _resumable = false;
        }
        StateHasChanged();
    }

    private async Task StartDownload()
    {
        await ExecuteDownload(resume: false);
    }

    private async Task ResumeDownload()
    {
        await ExecuteDownload(resume: true);
    }

    private async Task StartOver()
    {
        try
        {
            await JS.InvokeVoidAsync("abortDownload", Url, FileName);
        }
        catch { }
        _resumable = false;
        await ExecuteDownload(resume: false);
    }

    private async Task ExecuteDownload(bool resume)
    {
        _state = DownloadState.Downloading;
        _progress = 0;
        _speedText = "";
        _disabled = true;
        StateHasChanged();

        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("downloadFile", Url, FileName, _dotNetRef, resume);
        }
        catch
        {
            _state = DownloadState.Error;
            _speedText = "";
            _disabled = false;
            await CheckResumable();
        }
    }

    private async Task ResetAfterDelay()
    {
        await Task.Delay(2000);
        _state = DownloadState.Idle;
        _progress = 0;
        _speedText = "";
        _disabled = false;
        _resumable = false;
        StateHasChanged();
    }

    private static string FormatSpeed(long bytesPerSecond)
    {
        string[] units = { "B/s", "KB/s", "MB/s", "GB/s" };
        double speed = bytesPerSecond;
        int unit = 0;
        while (speed >= 1024 && unit < units.Length - 1) { speed /= 1024; unit++; }
        return $"{speed:0.#} {units[unit]}";
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("abortDownload", Url, FileName);
        }
        catch { }
        _dotNetRef?.Dispose();
    }

    private enum DownloadState { Idle, Downloading, Done, Error }
}
