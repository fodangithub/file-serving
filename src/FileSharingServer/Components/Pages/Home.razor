@page "/"
@using FileSharingServer.Services
@inject FileService FileService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>File Server</PageTitle>

<div class="file-browser @PanelClass">
    <div class="left-panel">
        <h3>Directories</h3>
        <div class="tree-root" @onclick="@(() => OnDirectorySelected(""))">
            <span class="tree-item @(string.IsNullOrEmpty(_currentPath) ? "active" : "")">Root</span>
        </div>
        <DirectoryTree Directories="@_rootDirs"
                       BasePath=""
                       CurrentPath="@_currentPath"
                       OnDirectorySelected="@OnDirectorySelected" />
    </div>
    <div class="panel-backdrop" @onclick="ClosePanel"></div>
    <div class="right-panel">
        <div class="panel-toolbar">
            <button class="panel-toggle" @onclick="TogglePanel" title="Toggle directory tree">
                <span class="panel-toggle-icon">&#x2630;</span>
            </button>
        </div>
        <div class="breadcrumb">
            <span @onclick="@(() => OnDirectorySelected(""))" class="crumb">Root</span>
            @foreach (var segment in GetBreadcrumbs())
            {
                <span class="separator">/</span>
                <span @onclick="@(() => OnDirectorySelected(segment.path))" class="crumb">@segment.name</span>
            }
        </div>

        <div class="search-bar">
            <input type="text"
                   class="search-input"
                   placeholder="Search files (partial text or * and ? wildcards, min 3 chars, max 200)..."
                   maxlength="200"
                   value="@_searchInput"
                   @oninput="OnSearchInput"
                   @onkeydown="OnSearchKey" />
            <button class="search-btn" @onclick="DoSearch" disabled="@_isSearching">Search</button>
            @if (_isSearching)
            {
                <span class="search-spinner"><span class="spinner"></span></span>
            }
            @if (!string.IsNullOrEmpty(_searchInput))
            {
                <button class="search-clear" @onclick="ClearSearch">&#x2715;</button>
            }
        </div>

        @if (_searchError != null)
        {
            <div class="search-error">@_searchError</div>
        }

        @if (_searchResults != null)
        {
            <div class="search-results">
                <div class="search-progress @(IsSearchComplete ? "complete" : "active")"></div>
                @if (_isSearching)
                {
                    <div class="search-summary search-status">
                        <span class="spinner-small"></span>
                        Searching for "<strong>@_searchQuery</strong>"... @_searchResults.Count result(s) found so far
                    </div>
                }
                else
                {
                    <div class="search-summary">
                        Found @_searchResults.Count result(s) for "<strong>@_searchQuery</strong>"
                    </div>
                }

                @if (_isSearching && _searchResults.Count == 0)
                {
                    <div class="skeleton-list">
                        @for (int i = 0; i < 6; i++)
                        {
                            <div class="skeleton-row">
                                <span class="skeleton skeleton-icon"></span>
                                <span class="skeleton skeleton-name"></span>
                                <span class="skeleton skeleton-size"></span>
                            </div>
                        }
                    </div>
                }

                @if (_searchResults.Count > 0)
                {
                    <div class="section">
                        @foreach (var result in _searchResults)
                        {
                            <div class="file-entry result-enter" @key="result.RelativePath">
                                <span class="icon">&#x1F4C4;</span>
                                <span class="name" title="@result.RelativePath">@result.RelativePath</span>
                                <span class="size">@FormatSize(result.Size)</span>
                                <DownloadButton Url="@($"/api/download?path={Uri.EscapeDataString(result.RelativePath)}")"
                                                FileName="@result.FileName" />
                            </div>
                        }
                    </div>
                }
                else if (!_isSearching)
                {
                    <div class="empty">No files matched your search.</div>
                }
            </div>
        }
        else
        {
            <FileList SubDirectories="@_currentSubDirs"
                      Files="@_currentFiles"
                      CurrentPath="@_currentPath"
                      OnNavigate="@OnDirectorySelected" />
        }
    </div>
</div>

@code {
    private string _currentPath = "";
    private List<System.IO.DirectoryInfo> _rootDirs = new();
    private List<System.IO.DirectoryInfo> _currentSubDirs = new();
    private List<System.IO.FileInfo> _currentFiles = new();

    private string _searchInput = "";
    private string? _searchQuery;
    private string? _searchError;
    private List<SearchResult>? _searchResults;
    private bool _isSearching;
    private CancellationTokenSource? _searchCts;

    private bool _toggled;
    private bool _panelOpen;

    private bool IsSearchComplete => !_isSearching;

    private string PanelClass
    {
        get
        {
            if (!_toggled) return "";
            return _panelOpen ? "panel-open" : "panel-closed";
        }
    }

    private void TogglePanel()
    {
        if (!_toggled)
        {
            _panelOpen = true;
            _toggled = true;
        }
        else
        {
            _panelOpen = !_panelOpen;
        }
    }

    private void ClosePanel()
    {
        if (_toggled && _panelOpen)
        {
            _panelOpen = false;
        }
        else if (!_toggled)
        {
            _panelOpen = false;
            _toggled = true;
        }
    }

    protected override void OnInitialized()
    {
        LoadDirectory("");
    }

    private void LoadDirectory(string path)
    {
        CancelOngoingSearch();
        _currentPath = path;
        _rootDirs = FileService.GetDirectories("");
        _currentSubDirs = FileService.GetDirectories(path);
        _currentFiles = FileService.GetFiles(path);
        ClearSearch();
    }

    private async void OnDirectorySelected(string path)
    {
        LoadDirectory(path);
        try
        {
            var width = await JS.InvokeAsync<double>("eval", "window.innerWidth");
            if (width < 768) ClosePanel();
        }
        catch { }
    }

    /// <summary>
    /// Called on every keystroke in the search input.
    /// Updates the bound value and cancels any in-flight search so stale results
    /// never keep arriving after the user has changed the query.
    /// </summary>
    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchInput = e.Value?.ToString() ?? "";
        CancelOngoingSearch();
    }

    private async void OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await DoSearch();
        }
    }

    private async Task DoSearch()
    {
        _searchError = null;

        if (string.IsNullOrWhiteSpace(_searchInput))
        {
            ClearSearch();
            return;
        }

        if (_searchInput.Length > FileService.MaxSearchPatternLength)
        {
            _searchError = $"Search pattern must be at most {FileService.MaxSearchPatternLength} characters.";
            _searchResults = null;
            _searchQuery = null;
            return;
        }

        if (!FileService.ValidateSearchPattern(_searchInput))
        {
            _searchError = "Pattern must be at least 3 characters and contain at least one non-wildcard character (not * ? .).";
            _searchResults = null;
            _searchQuery = null;
            return;
        }

        CancelOngoingSearch();
        var cts = new CancellationTokenSource();
        _searchCts = cts;
        var token = cts.Token;

        _isSearching = true;
        _searchQuery = _searchInput;
        _searchResults = new List<SearchResult>();
        StateHasChanged();

        var pending = new List<SearchResult>();

        try
        {
            await foreach (var result in FileService.SearchFilesAsync(_currentPath, _searchInput, token))
            {
                if (cts != _searchCts) return;

                pending.Add(result);
                if (pending.Count >= 5)
                {
                    _searchResults.AddRange(pending);
                    pending.Clear();
                    StateHasChanged();
                    await Task.Delay(50, token);
                }
            }

            if (pending.Count > 0 && cts == _searchCts)
            {
                _searchResults.AddRange(pending);
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            if (cts == _searchCts)
            {
                _isSearching = false;
                StateHasChanged();
            }
        }
    }

    private void CancelOngoingSearch()
    {
        if (_searchCts != null)
        {
            _searchCts.Cancel();
            _searchCts.Dispose();
            _searchCts = null;
        }
    }

    private void ClearSearch()
    {
        CancelOngoingSearch();
        _searchInput = "";
        _searchQuery = null;
        _searchError = null;
        _searchResults = null;
        _isSearching = false;
    }

    private List<(string name, string path)> GetBreadcrumbs()
    {
        if (string.IsNullOrEmpty(_currentPath))
            return new();

        var parts = _currentPath.Split('/', '\\');
        var result = new List<(string name, string path)>();
        var current = "";
        foreach (var part in parts)
        {
            current = string.IsNullOrEmpty(current) ? part : $"{current}/{part}";
            result.Add((part, current));
        }
        return result;
    }

    private string FormatSize(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int unit = 0;
        while (size >= 1024 && unit < units.Length - 1) { size /= 1024; unit++; }
        return $"{size:0.##} {units[unit]}";
    }
}
